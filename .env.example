# ── MongoDB Atlas ────────────────────────────────────────────────────────────
# Huong dan tao MONGO_URI:
#   1. Vao https://cloud.mongodb.com → tao tai khoan mien phi
#   2. Tao cluster M0 (free) → chon region gan Viet Nam (Singapore)
#   3. Database Access → tao user + password
#   4. Network Access → cho phep IP 0.0.0.0/0 (cho dev)
#   5. Connect → Drivers → sao chep connection string
#   6. Thay <password> bang mat khau vua tao, <dbname> bang "finance-app"
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── Anthropic API (tuy chon - danh cho tinh nang chat AI) ────────────────────
# Lay API key tai https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
